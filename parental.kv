                            text_color:       0.122, 0.227, 0.373, 1
                            size_hint_y:      None
                            height:           "24dp"
                        MDSwitch:
                            active:             True
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 0.424, 0.388, 1, 1

                WCard:
                    size_hint_y: None
                    height:      "62dp"
                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"
                        MDIcon:
                            icon:             "alert-outline"
                            theme_text_color: "Custom"
                            text_color:       1, 0.298, 0.298, 1
                            font_size:        "24sp"
                            size_hint_x:      None
                            width:            "30dp"
                        MDLabel:
                            text:             "Emergency Alerts"
                            font_size:        "14sp"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            size_hint_y:      None
                            height:           "24dp"
                        MDSwitch:
                            active:             True
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 0.424, 0.388, 1, 1

                STitle:
                    text: "Security"

                WCard:
                    size_hint_y: None
                    height:      "62dp"
                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"
                        MDIcon:
                            icon:             "lock-outline"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            font_size:        "24sp"
                            size_hint_x:      None
                            width:            "30dp"
                        MDLabel:
                            text:             "App Lock with PIN"
                            font_size:        "14sp"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            size_hint_y:      None
                            height:           "24dp"
                        MDSwitch:
                            active:             True
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 0.424, 0.388, 1, 1

                WCard:
                    size_hint_y: None
                    height:      "62dp"
                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"
                        MDIcon:
                            icon:             "fingerprint"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            font_size:        "24sp"
                            size_hint_x:      None
                            width:            "30dp"
                        MDLabel:
                            text:             "Biometric Login"
                            font_size:        "14sp"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            size_hint_y:      None
                            height:           "24dp"
                        MDSwitch:
                            active:      False
                            size_hint_x: None
                            width:       "56dp"

                STitle:
                    text: "General"

                WCard:
                    size_hint_y: None
                    height:      "62dp"
                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"
                        MDIcon:
                            icon:             "theme-light-dark"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            font_size:        "24sp"
                            size_hint_x:      None
                            width:            "30dp"
                        MDLabel:
                            text:             "Dark Mode"
                            font_size:        "14sp"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            size_hint_y:      None
                            height:           "24dp"
                        MDSwitch:
                            active:      False
                            size_hint_x: None
                            width:       "56dp"

                WCard:
                    size_hint_y: None
                    height:      "62dp"
                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"
                        MDIcon:
                            icon:             "translate"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            font_size:        "24sp"
                            size_hint_x:      None
                            width:            "30dp"
                        MDLabel:
                            text:             "Language: English"
                            font_size:        "14sp"
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            size_hint_y:      None
                            height:           "24dp"
                        MDIconButton:
                            icon:             "chevron-right"
                            theme_text_color: "Custom"
                            text_color:       0.478, 0.561, 0.651, 1

                Widget:
                    size_hint_y: None
                    height:      "8dp"

                PrimaryButton:
                    text:     "SAVE SETTINGS"
                    on_press: root.save_settings()

                Widget:
                    size_hint_y: None
                    height:      "8dp"

                DangerButton:
                    text:     "LOGOUT"
                    on_press: root.do_logout()

                Widget:
                    size_hint_y: None
                    height:      "16dp"

        MDBoxLayout:
            size_hint_y:  None
            height:       "68dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["4dp", "4dp"]

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "home-variant"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_back()
                MDLabel:
                    text: "Home"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "clock-time-four-outline"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_to("screen_time")
                MDLabel:
                    text: "Screen"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "map-marker-radius-outline"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_to("location")
                MDLabel:
                    text: "Location"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "cog-outline"
                    theme_text_color: "Custom"
                    text_color: 0.424, 0.388, 1, 1
                MDLabel:
                    text: "Settings"
                    halign: "center"
                    font_size: "10sp"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 0.424, 0.388, 1, 1
                    size_hint_y: None
                    height: "14dp"



# ==============================================================
#  SMART SCHEDULE SCREEN
# ==============================================================
<SmartScheduleScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        # ── Header ──────────────────────────────────────────
        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "158dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["20dp", "42dp", "20dp", "16dp"]
            spacing:      "8dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 32, 32]

            MDBoxLayout:
                adaptive_height: True
                spacing:         "8dp"

                MDIconButton:
                    icon:             "arrow-left"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    on_press:         root.go_back()

                MDLabel:
                    text:             "Smart Schedule"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_y:      None
                    height:           "36dp"

            MDLabel:
                text:             "Automatic time-based app access control"
                theme_text_color: "Custom"
                text_color:       0.600, 0.733, 0.900, 1
                font_size:        "13sp"
                size_hint_y:      None
                height:           "22dp"

        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["16dp", "16dp"]
                spacing:         "14dp"
                adaptive_height: True

                # ── LIVE STATUS CARD ─────────────────────────
                MDCard:
                    size_hint_y:  None
                    height:       "140dp"
                    md_bg_color:  0.122, 0.227, 0.373, 1
                    radius:       [20, 20, 20, 20]
                    elevation:    4
                    padding:      "18dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "8dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "10dp"

                            MDIcon:
                                icon:             "clock-check-outline"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                font_size:        "28sp"
                                size_hint_x:      None
                                width:            "36dp"

                            MDBoxLayout:
                                orientation:     "vertical"
                                adaptive_height: True
                                spacing:         "4dp"

                                MDLabel:
                                    id:               current_slot_label
                                    text:             "Loading..."
                                    font_size:        "20sp"
                                    bold:             True
                                    theme_text_color: "Custom"
                                    text_color:       1, 1, 1, 1
                                    size_hint_y:      None
                                    height:           "28dp"

                                MDLabel:
                                    id:               status_message
                                    text:             "Checking..."
                                    font_size:        "13sp"
                                    theme_text_color: "Custom"
                                    text_color:       0.600, 0.733, 0.900, 1
                                    size_hint_y:      None
                                    height:           "22dp"

                            MDLabel:
                                id:               current_time_label
                                text:             "--:--"
                                font_size:        "18sp"
                                bold:             True
                                halign:           "right"
                                theme_text_color: "Custom"
                                text_color:       1, 1, 1, 1
                                size_hint_y:      None
                                height:           "28dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "16dp"

                            MDLabel:
                                id:               time_remaining
                                text:             ""
                                font_size:        "12sp"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.700, 1, 1
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                id:               next_slot_label
                                text:             ""
                                halign:           "right"
                                font_size:        "12sp"
                                theme_text_color: "Custom"
                                text_color:       0.600, 0.800, 0.600, 1
                                size_hint_y:      None
                                height:           "20dp"

                # ── 4 SLOT CARDS ─────────────────────────────
                MDLabel:
                    text:             "Daily Schedule"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.122, 0.227, 0.373, 1
                    size_hint_y:      None
                    height:           "34dp"

                # School Time
                MDCard:
                    size_hint_y:  None
                    height:       "100dp"
                    md_bg_color:  1, 0.950, 0.950, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    2
                    padding:      "16dp"

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "48dp", "48dp"
                            radius:      [24, 24, 24, 24]
                            md_bg_color: 1, 0.298, 0.298, 0.15

                            MDIcon:
                                icon:             "school-outline"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                font_size:        "26sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "4dp"

                            MDLabel:
                                text:             "School Time"
                                font_size:        "16sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "26dp"

                            MDLabel:
                                text:             "8:00 AM  --  2:00 PM"
                                font_size:        "13sp"
                                theme_text_color: "Custom"
                                text_color:       0.478, 0.561, 0.651, 1
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "All apps blocked"
                                font_size:        "12sp"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDCard:
                            size_hint_y:  None
                            height:       "28dp"
                            size_hint_x:  None
                            width:        "72dp"
                            md_bg_color:  1, 0.298, 0.298, 0.15
                            radius:       [14, 14, 14, 14]
                            padding:      ["6dp", "4dp"]

                            MDLabel:
                                text:             "BLOCKED"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                font_size:        "10sp"
                                bold:             True
                                halign:           "center"

                # Break Time
                MDCard:
                    size_hint_y:  None
                    height:       "100dp"
                    md_bg_color:  1, 0.984, 0.930, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    2
                    padding:      "16dp"

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "48dp", "48dp"
                            radius:      [24, 24, 24, 24]
                            md_bg_color: 0.980, 0.600, 0.100, 0.15

                            MDIcon:
                                icon:             "coffee-outline"
                                theme_text_color: "Custom"
                                text_color:       0.980, 0.600, 0.100, 1
                                font_size:        "26sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "4dp"

                            MDLabel:
                                text:             "Break Time"
                                font_size:        "16sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "26dp"

                            MDLabel:
                                text:             "2:00 PM  --  3:00 PM"
                                font_size:        "13sp"
                                theme_text_color: "Custom"
                                text_color:       0.478, 0.561, 0.651, 1
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "Allowed: WhatsApp, SMS only"
                                font_size:        "12sp"
                                theme_text_color: "Custom"
                                text_color:       0.980, 0.600, 0.100, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDCard:
                            size_hint_y:  None
                            height:       "28dp"
                            size_hint_x:  None
                            width:        "72dp"
                            md_bg_color:  0.980, 0.600, 0.100, 0.15
                            radius:       [14, 14, 14, 14]
                            padding:      ["6dp", "4dp"]

                            MDLabel:
                                text:             "LIMITED"
                                theme_text_color: "Custom"
                                text_color:       0.980, 0.600, 0.100, 1
                                font_size:        "10sp"
                                bold:             True
                                halign:           "center"

                # Home Time
                MDCard:
                    size_hint_y:  None
                    height:       "100dp"
                    md_bg_color:  0.940, 0.980, 0.940, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    2
                    padding:      "16dp"

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "48dp", "48dp"
                            radius:      [24, 24, 24, 24]
                            md_bg_color: 0.298, 0.686, 0.314, 0.15

                            MDIcon:
                                icon:             "home-outline"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                font_size:        "26sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "4dp"

                            MDLabel:
                                text:             "Home Time"
                                font_size:        "16sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "26dp"

                            MDLabel:
                                text:             "3:00 PM  --  10:00 PM"
                                font_size:        "13sp"
                                theme_text_color: "Custom"
                                text_color:       0.478, 0.561, 0.651, 1
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "All apps allowed"
                                font_size:        "12sp"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDCard:
                            size_hint_y:  None
                            height:       "28dp"
                            size_hint_x:  None
                            width:        "72dp"
                            md_bg_color:  0.298, 0.686, 0.314, 0.15
                            radius:       [14, 14, 14, 14]
                            padding:      ["6dp", "4dp"]

                            MDLabel:
                                text:             "OPEN"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                font_size:        "10sp"
                                bold:             True
                                halign:           "center"

                # Sleep Time
                MDCard:
                    size_hint_y:  None
                    height:       "100dp"
                    md_bg_color:  0.945, 0.941, 0.980, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    2
                    padding:      "16dp"

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "48dp", "48dp"
                            radius:      [24, 24, 24, 24]
                            md_bg_color: 0.424, 0.388, 1, 0.15

                            MDIcon:
                                icon:             "sleep"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                font_size:        "26sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "4dp"

                            MDLabel:
                                text:             "Sleep Time"
                                font_size:        "16sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "26dp"

                            MDLabel:
                                text:             "10:00 PM  --  8:00 AM"
                                font_size:        "13sp"
                                theme_text_color: "Custom"
                                text_color:       0.478, 0.561, 0.651, 1
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "All apps blocked"
                                font_size:        "12sp"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDCard:
                            size_hint_y:  None
                            height:       "28dp"
                            size_hint_x:  None
                            width:        "72dp"
                            md_bg_color:  0.424, 0.388, 1, 0.15
                            radius:       [14, 14, 14, 14]
                            padding:      ["6dp", "4dp"]

                            MDLabel:
                                text:             "BLOCKED"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                font_size:        "10sp"
                                bold:             True
                                halign:           "center"

                # ── CUSTOMIZE TIMES ──────────────────────────
                MDLabel:
                    text:             "Customize Times"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.122, 0.227, 0.373, 1
                    size_hint_y:      None
                    height:           "34dp"

                # School fields
                MDCard:
                    size_hint_y:  None
                    height:       "130dp"
                    md_bg_color:  1, 1, 1, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    2
                    padding:      "16dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "10dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "8dp"

                            MDIcon:
                                icon:             "school-outline"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                font_size:        "20sp"
                                size_hint_x:      None
                                width:            "26dp"

                            MDLabel:
                                text:             "School Time"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "26dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "12dp"

                            MDTextField:
                                id:               school_start
                                hint_text:        "Start"
                                text:             "08:00"
                                mode:             "rectangle"
                                font_size:        "14sp"
                                line_color_focus: 1, 0.298, 0.298, 1

                            MDTextField:
                                id:               school_end
                                hint_text:        "End"
                                text:             "14:00"
                                mode:             "rectangle"
                                font_size:        "14sp"
                                line_color_focus: 1, 0.298, 0.298, 1

                # Break fields
                MDCard:
                    size_hint_y:  None
                    height:       "175dp"
                    md_bg_color:  1, 1, 1, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    2
                    padding:      "16dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "10dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "8dp"

                            MDIcon:
                                icon:             "coffee-outline"
                                theme_text_color: "Custom"
                                text_color:       0.980, 0.600, 0.100, 1
                                font_size:        "20sp"
                                size_hint_x:      None
                                width:            "26dp"

                            MDLabel:
                                text:             "Break Time"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "26dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "12dp"

                            MDTextField:
                                id:               break_start
                                hint_text:        "Start"
                                text:             "14:00"
                                mode:             "rectangle"
                                font_size:        "14sp"
                                line_color_focus: 0.980, 0.600, 0.100, 1

                            MDTextField:
                                id:               break_end
                                hint_text:        "End"
                                text:             "15:00"
                                mode:             "rectangle"
                                font_size:        "14sp"
                                line_color_focus: 0.980, 0.600, 0.100, 1

                        MDTextField:
                            id:               break_apps
                            hint_text:        "Allowed apps (WhatsApp, SMS)"
                            text:             "WhatsApp, SMS"
                            mode:             "rectangle"
                            font_size:        "14sp"
                            line_color_focus: 0.980, 0.600, 0.100, 1

                # Home fields
                MDCard:
                    size_hint_y:  None
                    height:       "130dp"
                    md_bg_color:  1, 1, 1, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    2
                    padding:      "16dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "10dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "8dp"

                            MDIcon:
                                icon:             "home-outline"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                font_size:        "20sp"
                                size_hint_x:      None
                                width:            "26dp"

                            MDLabel:
                                text:             "Home Time"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "26dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "12dp"

                            MDTextField:
                                id:               home_start
                                hint_text:        "Start"
                                text:             "15:00"
                                mode:             "rectangle"
                                font_size:        "14sp"
                                line_color_focus: 0.298, 0.686, 0.314, 1

                            MDTextField:
                                id:               home_end
                                hint_text:        "End"
                                text:             "22:00"
                                mode:             "rectangle"
                                font_size:        "14sp"
                                line_color_focus: 0.298, 0.686, 0.314, 1

                # Sleep fields
                MDCard:
                    size_hint_y:  None
                    height:       "130dp"
                    md_bg_color:  1, 1, 1, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    2
                    padding:      "16dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "10dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "8dp"

                            MDIcon:
                                icon:             "sleep"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                font_size:        "20sp"
                                size_hint_x:      None
                                width:            "26dp"

                            MDLabel:
                                text:             "Sleep Time"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "26dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "12dp"

                            MDTextField:
                                id:               sleep_start
                                hint_text:        "Start"
                                text:             "22:00"
                                mode:             "rectangle"
                                font_size:        "14sp"
                                line_color_focus: 0.424, 0.388, 1, 1

                            MDTextField:
                                id:               sleep_end
                                hint_text:        "End"
                                text:             "08:00"
                                mode:             "rectangle"
                                font_size:        "14sp"
                                line_color_focus: 0.424, 0.388, 1, 1

                Widget:
                    size_hint_y: None
                    height:      "8dp"

                # Save Button
                MDRaisedButton:
                    text:        "SAVE SCHEDULE"
                    md_bg_color: 0.424, 0.388, 1, 1
                    text_color:  1, 1, 1, 1
                    font_size:   "15sp"
                    elevation:   4
                    size_hint_x: 1
                    height:      "54dp"
                    radius:      [27, 27, 27, 27]
                    on_press:    root.save_schedule()

                Widget:
                    size_hint_y: None
                    height:      "16dp"

        # ── Bottom Nav ───────────────────────────────────────
        MDBoxLayout:
            size_hint_y:  None
            height:       "68dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["4dp", "4dp"]

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "home-variant"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_back()
                MDLabel:
                    text:             "Home"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "clock-time-four-outline"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_to("screen_time")
                MDLabel:
                    text:             "Screen"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "calendar-clock"
                    theme_text_color: "Custom"
                    text_color:       0.424, 0.388, 1, 1
                MDLabel:
                    text:             "Schedule"
                    halign:           "center"
                    font_size:        "10sp"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.424, 0.388, 1, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "cog-outline"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_to("settings")
                MDLabel:
                    text:             "Settings"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"

# ==============================================================
#  SCREEN 6 -- SCREEN TIME
# ==============================================================
<ScreenTimeScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        # Header
        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "158dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["20dp", "42dp", "20dp", "16dp"]
            spacing:      "8dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 32, 32]

            MDBoxLayout:
                adaptive_height: True
                spacing:         "8dp"
                MDIconButton:
                    icon:             "arrow-left"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    on_press:         root.go_back()
                MDLabel:
                    text:             "Screen Time"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_y:      None
                    height:           "36dp"

            MDLabel:
                text:             "Set and monitor daily screen limits"
                theme_text_color: "Custom"
                text_color:       0.600, 0.733, 0.900, 1
                font_size:        "13sp"
                size_hint_y:      None
                height:           "22dp"

        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["16dp", "16dp"]
                spacing:         "14dp"
                adaptive_height: True

                # Today usage card
                MDLabel:
                    text:             "Today's Usage"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.122, 0.227, 0.373, 1
                    size_hint_y:      None
                    height:           "34dp"

                WCard:
                    size_hint_y: None
                    height:      "145dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "12dp"

                        MDBoxLayout:
                            adaptive_height: True
                            MDLabel:
                                text:             "2 hours 15 minutes"
                                font_size:        "18sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "28dp"
                            MDLabel:
                                text:             "56%"
                                halign:           "right"
                                font_size:        "18sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                size_hint_y:      None
                                height:           "28dp"

                        MDProgressBar:
                            value:       56
                            color:       0.424, 0.388, 1, 1
                            size_hint_y: None
                            height:      "12dp"

                        MDLabel:
                            text:             "Limit: 4 hours  --  1h 45m remaining"
                            theme_text_color: "Custom"
                            text_color:       0.478, 0.561, 0.651, 1
                            font_size:        "12sp"
                            size_hint_y:      None
                            height:           "20dp"

                        MDCard:
                            size_hint_y:  None
                            height:       "26dp"
                            size_hint_x:  None
                            width:        "90dp"
                            md_bg_color:  0.298, 0.686, 0.314, 0.15
                            radius:       [13, 13, 13, 13]
                            padding:      ["8dp", "4dp"]
                            MDLabel:
                                text:             "Safe Range"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                font_size:        "11sp"
                                bold:             True
                                halign:           "center"

                # Set limit slider
                MDLabel:
                    text:             "Set Daily Limit"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.122, 0.227, 0.373, 1
                    size_hint_y:      None
                    height:           "34dp"

                WCard:
                    size_hint_y: None
                    height:      "90dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "8dp"

                        MDBoxLayout:
                            adaptive_height: True
                            MDLabel:
                                text:             "Drag to adjust"
                                font_size:        "13sp"
                                theme_text_color: "Custom"
                                text_color:       0.478, 0.561, 0.651, 1
                                size_hint_y:      None
                                height:           "22dp"
                            MDLabel:
                                id:               limit_label
                                text:             "240 min/day"
                                halign:           "right"
                                font_size:        "14sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                size_hint_y:      None
                                height:           "22dp"

                        MDSlider:
                            min:      30
                            max:      480
                            value:    240
                            color:    0.424, 0.388, 1, 1
                            on_value: root.set_limit(self.value)

                # Quick presets
                MDLabel:
                    text:             "Quick Presets"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.122, 0.227, 0.373, 1
                    size_hint_y:      None
                    height:           "34dp"

                MDGridLayout:
                    cols:            3
                    spacing:         "10dp"
                    adaptive_height: True

                    MDRaisedButton:
                        text:        "1 Hour"
                        on_press:    root.set_limit(60)
                        md_bg_color: 1, 1, 1, 1
                        text_color:  0.122, 0.227, 0.373, 1
                        elevation:   1
                        size_hint_y: None
                        height:      "44dp"
                        radius:      [12, 12, 12, 12]

                    MDRaisedButton:
                        text:        "2 Hours"
                        on_press:    root.set_limit(120)
                        md_bg_color: 1, 1, 1, 1
                        text_color:  0.122, 0.227, 0.373, 1
                        elevation:   1
                        size_hint_y: None
                        height:      "44dp"
                        radius:      [12, 12, 12, 12]

                    MDRaisedButton:
                        text:        "3 Hours"
                        on_press:    root.set_limit(180)
                        md_bg_color: 1, 1, 1, 1
                        text_color:  0.122, 0.227, 0.373, 1
                        elevation:   1
                        size_hint_y: None
                        height:      "44dp"
                        radius:      [12, 12, 12, 12]

                    MDRaisedButton:
                        text:        "4 Hours"
                        on_press:    root.set_limit(240)
                        md_bg_color: 0.424, 0.388, 1, 1
                        text_color:  1, 1, 1, 1
                        elevation:   3
                        size_hint_y: None
                        height:      "44dp"
                        radius:      [12, 12, 12, 12]

                    MDRaisedButton:
                        text:        "5 Hours"
                        on_press:    root.set_limit(300)
                        md_bg_color: 1, 1, 1, 1
                        text_color:  0.122, 0.227, 0.373, 1
                        elevation:   1
                        size_hint_y: None
                        height:      "44dp"
                        radius:      [12, 12, 12, 12]

                    MDRaisedButton:
                        text:        "No Limit"
                        on_press:    root.set_limit(480)
                        md_bg_color: 1, 1, 1, 1
                        text_color:  1, 0.298, 0.298, 1
                        elevation:   1
                        size_hint_y: None
                        height:      "44dp"
                        radius:      [12, 12, 12, 12]

                # Weekly chart
                MDLabel:
                    text:             "This Week"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.122, 0.227, 0.373, 1
                    size_hint_y:      None
                    height:           "34dp"

                WCard:
                    size_hint_y: None
                    height:      "210dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "10dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing: "8dp"
                            MDLabel:
                                text: "Mon"
                                font_size: "12sp"
                                theme_text_color: "Custom"
                                text_color: 0.478, 0.561, 0.651, 1
                                size_hint_x: None
                                width: "36dp"
                            MDProgressBar:
                                value: 75
                                color: 0.424, 0.388, 1, 1
                                size_hint_y: None
                                height: "8dp"
                            MDLabel:
                                text: "3h"
                                font_size: "12sp"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.122, 0.227, 0.373, 1
                                size_hint_x: None
                                width: "28dp"
                                halign: "right"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing: "8dp"
                            MDLabel:
                                text: "Tue"
                                font_size: "12sp"
                                theme_text_color: "Custom"
                                text_color: 0.478, 0.561, 0.651, 1
                                size_hint_x: None
                                width: "36dp"
                            MDProgressBar:
                                value: 50
                                color: 0.298, 0.686, 0.314, 1
                                size_hint_y: None
                                height: "8dp"
                            MDLabel:
                                text: "2h"
                                font_size: "12sp"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.122, 0.227, 0.373, 1
                                size_hint_x: None
                                width: "28dp"
                                halign: "right"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing: "8dp"
                            MDLabel:
                                text: "Wed"
                                font_size: "12sp"
                                theme_text_color: "Custom"
                                text_color: 0.478, 0.561, 0.651, 1
                                size_hint_x: None
                                width: "36dp"
                            MDProgressBar:
                                value: 100
                                color: 1, 0.298, 0.298, 1
                                size_hint_y: None
                                height: "8dp"
                            MDLabel:
                                text: "4h+"
                                font_size: "12sp"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 1, 0.298, 0.298, 1
                                size_hint_x: None
                                width: "28dp"
                                halign: "right"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing: "8dp"
                            MDLabel:
                                text: "Thu"
                                font_size: "12sp"
                                theme_text_color: "Custom"
                                text_color: 0.478, 0.561, 0.651, 1
                                size_hint_x: None
                                width: "36dp"
                            MDProgressBar:
                                value: 30
                                color: 0.298, 0.686, 0.314, 1
                                size_hint_y: None
                                height: "8dp"
                            MDLabel:
                                text: "1h"
                                font_size: "12sp"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.122, 0.227, 0.373, 1
                                size_hint_x: None
                                width: "28dp"
                                halign: "right"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing: "8dp"
                            MDLabel:
                                text: "Fri"
                                font_size: "12sp"
                                theme_text_color: "Custom"
                                text_color: 0.478, 0.561, 0.651, 1
                                size_hint_x: None
                                width: "36dp"
                            MDProgressBar:
                                value: 56
                                color: 0.424, 0.388, 1, 1
                                size_hint_y: None
                                height: "8dp"
                            MDLabel:
                                text: "2h+"
                                font_size: "12sp"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 0.122, 0.227, 0.373, 1
                                size_hint_x: None
                                width: "28dp"
                                halign: "right"

                Widget:
                    size_hint_y: None
                    height:      "12dp"

        # Bottom Nav
        MDBoxLayout:
            size_hint_y:  None
            height:       "68dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["4dp", "4dp"]

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "home-variant"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_back()
                MDLabel:
                    text: "Home"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "clock-time-four-outline"
                    theme_text_color: "Custom"
                    text_color: 0.424, 0.388, 1, 1
                MDLabel:
                    text: "Screen"
                    halign: "center"
                    font_size: "10sp"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 0.424, 0.388, 1, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "map-marker-radius-outline"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_to("location")
                MDLabel:
                    text: "Location"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "cog-outline"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_to("settings")
                MDLabel:
                    text: "Settings"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

# ==============================================================
#  END OF parental.kv