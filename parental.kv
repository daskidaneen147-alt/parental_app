# ==============================================================
#  SCREEN 7 -- LOCATION
# ==============================================================
<LocationScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "158dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["20dp", "42dp", "20dp", "16dp"]
            spacing:      "8dp"
