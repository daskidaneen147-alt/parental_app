# ==============================================================
#  SCREEN 8 -- NOTIFICATIONS
# ==============================================================
# ==============================================================
#  notifications_screen.kv
#  parental.kv mein purana <NotificationsScreen>: replace karo
# ==============================================================

<NotificationsScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        # Header
        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "158dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["20dp", "42dp", "20dp", "16dp"]
            spacing:      "8dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 32, 32]

            MDBoxLayout:
                adaptive_height: True
                spacing:         "8dp"

                MDIconButton:
                    icon:             "arrow-left"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    on_press:         root.go_back()

                MDLabel:
                    text:             "Alerts and Notifications"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_y:      None
                    height:           "36dp"

            MDBoxLayout:
                adaptive_height: True
                spacing:         "10dp"

                MDCard:
                    size_hint_y:  None
                    height:       "28dp"
                    size_hint_x:  None
                    width:        "100dp"
                    md_bg_color:  1, 0.298, 0.298, 0.20
                    radius:       [14, 14, 14, 14]
                    padding:      ["8dp", "4dp"]

                    MDLabel:
                        id:               notif_badge
                        text:             "Loading..."
                        theme_text_color: "Custom"
                        text_color:       1, 0.600, 0.600, 1
                        font_size:        "12sp"
                        bold:             True
                        halign:           "center"

                MDFlatButton:
                    text:       "Mark All Read"
                    text_color: 0.700, 0.800, 1, 1
                    on_press:   root.clear_all()

        # Notification list -- Python se dynamically fill hoga
        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["16dp", "14dp"]
                spacing:         "10dp"
                adaptive_height: True

                MDBoxLayout:
                    id:              notif_container
                    orientation:     "vertical"
                    spacing:         "10dp"
                    adaptive_height: True

                    # Default loading
                    MDLabel:
                        text:             "Loading notifications..."
                        halign:           "center"
                        theme_text_color: "Custom"
                        text_color:       0.478, 0.561, 0.651, 1
                        font_size:        "14sp"
                        size_hint_y:      None
                        height:           "60dp"

                Widget:
                    size_hint_y: None
                    height:      "12dp"

        # Bottom Nav
        MDBoxLayout:
            size_hint_y:  None
            height:       "68dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["4dp", "4dp"]

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "home-variant"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_back()
                MDLabel:
                    text: "Home"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "clock-time-four-outline"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_to("screen_time")
                MDLabel:
                    text: "Screen"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "map-marker-radius-outline"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_to("location")
                MDLabel:
                    text: "Location"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "bell-outline"
                    theme_text_color: "Custom"
                    text_color: 0.424, 0.388, 1, 1
                MDLabel:
                    text: "Alerts"
                    halign: "center"
                    font_size: "10sp"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 0.424, 0.388, 1, 1
                    size_hint_y: None
                    height: "14dp"


