                                text_color:       0.478, 0.561, 0.651, 1
                                font_size:        "16sp"
                            MDLabel:
                                text:             "Ahmed"
                                theme_text_color: "Custom"
                                text_color:       0.478, 0.561, 0.651, 1
                                font_size:        "14sp"
                                halign:           "center"

                STitle:
