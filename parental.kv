# ==============================================================
#  parental.kv  --  GuardianEye Parental Control App
#  Design: Kids360 Login + Qustodio Dashboard + Family Link Location
#  KivyMD 1.1.1 compatible
# ==============================================================


# --------------------------------------------------------------
#  REUSABLE: Purple Primary Button
# --------------------------------------------------------------
<PrimaryButton@MDRaisedButton>:
    md_bg_color: 0.424, 0.388, 1, 1
    text_color:  1, 1, 1, 1
    font_size:   "15sp"
    elevation:   4
    size_hint_x: 1
    height:      "54dp"
    radius:      [27, 27, 27, 27]


# --------------------------------------------------------------
#  REUSABLE: Red Danger Button
# --------------------------------------------------------------
<DangerButton@MDRaisedButton>:
    md_bg_color: 1, 0.298, 0.298, 1
    text_color:  1, 1, 1, 1
    font_size:   "15sp"
    elevation:   2
    size_hint_x: 1
    height:      "52dp"
    radius:      [26, 26, 26, 26]


# --------------------------------------------------------------
#  REUSABLE: White Card
# --------------------------------------------------------------
<WCard@MDCard>:
    md_bg_color: 1, 1, 1, 1
    elevation:   3
    radius:      [20, 20, 20, 20]
    padding:     "18dp"


# --------------------------------------------------------------
#  REUSABLE: Section Title
# --------------------------------------------------------------
<STitle@MDLabel>:
    font_style:       "H6"
    theme_text_color: "Custom"
    text_color:       0.122, 0.227, 0.373, 1
    bold:             True
    size_hint_y:      None
    height:           "34dp"


# --------------------------------------------------------------
#  REUSABLE: Small Grey Label
# --------------------------------------------------------------
<SGrey@MDLabel>:
    theme_text_color: "Custom"
    text_color:       0.478, 0.561, 0.651, 1
    font_size:        "12sp"
    size_hint_y:      None
    height:           "20dp"

# ==============================================================
#  splash_screen.kv
#  parental.kv ke BILKUL SHURU mein paste karo
#  (sabse pehle -- kisi bhi screen se pehle)
# ==============================================================

<SplashScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.122, 0.227, 0.373, 1

        # Top space
        Widget:
            size_hint_y: 0.15

        # Logo circle
        MDBoxLayout:
            size_hint_y:  None
            height:       "140dp"
            pos_hint:     {"center_x": 0.5}

            MDCard:
                id:          logo_card
                size_hint:   None, None
                size:        "120dp", "120dp"
                radius:      [60, 60, 60, 60]
                md_bg_color: 0.424, 0.388, 1, 1
                elevation:   12
                opacity:     0
                pos_hint:    {"center_x": 0.5}

                MDBoxLayout:
                    orientation: "vertical"
                    spacing:     "4dp"
                    padding:     "16dp"

                    MDIcon:
                        icon:             "shield-account"
                        theme_text_color: "Custom"
                        text_color:       1, 1, 1, 1
                        font_size:        "56sp"
                        halign:           "center"

        # App name
        MDLabel:
            id:               app_name
            text:             "GuardianEye"
            font_style:       "H3"
            bold:             True
            halign:           "center"
            theme_text_color: "Custom"
            text_color:       1, 1, 1, 1
            opacity:          0
            size_hint_y:      None
            height:           "60dp"

        # Tagline
        MDLabel:
            id:               tagline
            text:             "Smart Parental Control"
            halign:           "center"
            theme_text_color: "Custom"
            text_color:       0.600, 0.733, 0.900, 1
            font_size:        "16sp"
            opacity:          0
            size_hint_y:      None
            height:           "30dp"

        Widget:
            size_hint_y: 0.08

        # Features row
        MDBoxLayout:
            size_hint_y:  None
            height:       "80dp"
            padding:      ["32dp", "0dp"]
            spacing:      "24dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "4dp"

                MDIcon:
                    icon:             "shield-lock-outline"
                    theme_text_color: "Custom"
                    text_color:       0.424, 0.388, 1, 1
                    font_size:        "28sp"
                    halign:           "center"

                MDLabel:
                    text:             "Protect"
                    halign:           "center"
                    theme_text_color: "Custom"
                    text_color:       0.600, 0.733, 0.900, 1
                    font_size:        "12sp"
                    size_hint_y:      None
                    height:           "20dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "4dp"

                MDIcon:
                    icon:             "map-marker-radius-outline"
                    theme_text_color: "Custom"
                    text_color:       0.298, 0.686, 0.314, 1
                    font_size:        "28sp"
                    halign:           "center"

                MDLabel:
                    text:             "Track"
                    halign:           "center"
                    theme_text_color: "Custom"
                    text_color:       0.600, 0.733, 0.900, 1
                    font_size:        "12sp"
                    size_hint_y:      None
                    height:           "20dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "4dp"

                MDIcon:
                    icon:             "clock-check-outline"
                    theme_text_color: "Custom"
                    text_color:       0.980, 0.600, 0.100, 1
                    font_size:        "28sp"
                    halign:           "center"

                MDLabel:
                    text:             "Schedule"
                    halign:           "center"
                    theme_text_color: "Custom"
                    text_color:       0.600, 0.733, 0.900, 1
                    font_size:        "12sp"
                    size_hint_y:      None
                    height:           "20dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "4dp"

                MDIcon:
                    icon:             "bell-check-outline"
                    theme_text_color: "Custom"
                    text_color:       1, 0.298, 0.298, 1
                    font_size:        "28sp"
                    halign:           "center"

                MDLabel:
                    text:             "Alert"
                    halign:           "center"
                    theme_text_color: "Custom"
                    text_color:       0.600, 0.733, 0.900, 1
                    font_size:        "12sp"
                    size_hint_y:      None
                    height:           "20dp"

        # Spacer
        Widget:
            size_hint_y: 0.15

        # Loading section
        MDBoxLayout:
            id:           loading_bar
            orientation:  "vertical"
            size_hint_y:  None
            height:       "60dp"
            padding:      ["48dp", "0dp"]
            spacing:      "8dp"
            opacity:      0

            MDProgressBar:
                id:          progress
                value:       0
                color:       0.424, 0.388, 1, 1
                size_hint_y: None
                height:      "6dp"

            MDLabel:
                text:             "Loading GuardianEye..."
                halign:           "center"
                theme_text_color: "Custom"
                text_color:       0.478, 0.561, 0.651, 1
                font_size:        "12sp"
                size_hint_y:      None
                height:           "20dp"

        # Bottom space
        Widget:
            size_hint_y: 0.08

        # Version
        MDLabel:
            text:             "Version 1.0  --  Final Year Project"
            halign:           "center"
            theme_text_color: "Custom"
            text_color:       0.300, 0.420, 0.540, 1
            font_size:        "11sp"
            size_hint_y:      None
            height:           "24dp"

        Widget:
            size_hint_y: None
            height:      "16dp"


# ==============================================================
#  SCREEN 1 -- LOGIN
# ==============================================================
<LoginScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        # Top navy hero
        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "300dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["32dp", "52dp", "32dp", "32dp"]
            spacing:      "10dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 48, 48]

            # Shield icon circle
            MDCard:
                size_hint:   None, None
                size:        "88dp", "88dp"
                radius:      [44, 44, 44, 44]
                md_bg_color: 0.424, 0.388, 1, 1
                elevation:   6
                pos_hint:    {"center_x": 0.5}

                MDIcon:
                    icon:             "shield-account"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    font_size:        "48sp"
                    halign:           "center"

            MDLabel:
                text:             "GuardianEye"
                font_style:       "H4"
                bold:             True
                halign:           "center"
                theme_text_color: "Custom"
                text_color:       1, 1, 1, 1
                size_hint_y:      None
                height:           "48dp"

            MDLabel:
                text:             "Smart Parental Control"
                halign:           "center"
                theme_text_color: "Custom"
                text_color:       0.600, 0.733, 0.900, 1
                font_size:        "14sp"
                size_hint_y:      None
                height:           "24dp"

        # Form section
        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["24dp", "20dp"]
                spacing:         "14dp"
                adaptive_height: True

                WCard:
                    size_hint_y: None
                    height:      "310dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "14dp"

                        MDLabel:
                            text:             "Welcome Back"
                            font_size:        "20sp"
                            bold:             True
                            theme_text_color: "Custom"
                            text_color:       0.122, 0.227, 0.373, 1
                            size_hint_y:      None
                            height:           "30dp"

                        SGrey:
                            text:   "Sign in to monitor your children"
                            height: "22dp"

                        MDTextField:
                            id:               email_field
                            hint_text:        "Email Address"
                            icon_right:       "email-outline"
                            mode:             "rectangle"
                            font_size:        "14sp"
                            line_color_focus: 0.424, 0.388, 1, 1

                        MDTextField:
                            id:               password_field
                            hint_text:        "Password"
                            icon_right:       "eye-outline"
                            password:         True
                            mode:             "rectangle"
                            font_size:        "14sp"
                            line_color_focus: 0.424, 0.388, 1, 1

                        MDLabel:
                            id:               error_label
                            text:             ""
                            theme_text_color: "Custom"
                            text_color:       1, 0.298, 0.298, 1
                            font_size:        "12sp"
                            size_hint_y:      None
                            height:           "18dp"

                        PrimaryButton:
                            text:     "LOGIN"
                            on_press: root.do_login()

                MDBoxLayout:
                    adaptive_height: True
                    spacing:         "4dp"
                    padding:         ["8dp", "0dp"]

                    SGrey:
                        text:        "Don't have an account?"
                        size_hint_x: 0.6
                        height:      "28dp"

                    MDFlatButton:
                        text:       "Sign Up Free"
                        text_color: 0.424, 0.388, 1, 1
                        on_press:   root.go_to_signup()


# ==============================================================
#  SCREEN 2 -- SIGN UP
# ==============================================================
<SignupScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "200dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["24dp", "44dp", "24dp", "20dp"]
            spacing:      "8dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 40, 40]

            MDBoxLayout:
                adaptive_height: True
                spacing:         "4dp"

                MDIconButton:
                    icon:             "arrow-left"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_x:      None
                    width:            "40dp"
                    on_press:         root.go_to_login()

                MDLabel:
                    text:             "Create Account"
                    font_style:       "H5"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_y:      None
                    height:           "40dp"

            MDLabel:
                text:             "Protect your family starting today"
                theme_text_color: "Custom"
                text_color:       0.600, 0.733, 0.900, 1
                font_size:        "13sp"
                size_hint_y:      None
                height:           "22dp"

            # Step dots
            MDBoxLayout:
                adaptive_height: True
                spacing:         "8dp"
                padding:         ["4dp", "0dp"]

                MDCard:
                    size_hint:   None, None
                    size:        "32dp", "6dp"
                    radius:      [3, 3, 3, 3]
                    md_bg_color: 0.424, 0.388, 1, 1

                MDCard:
                    size_hint:   None, None
                    size:        "16dp", "6dp"
                    radius:      [3, 3, 3, 3]
                    md_bg_color: 0.400, 0.533, 0.667, 1

                MDCard:
                    size_hint:   None, None
                    size:        "16dp", "6dp"
                    radius:      [3, 3, 3, 3]
                    md_bg_color: 0.400, 0.533, 0.667, 1

        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["24dp", "20dp"]
                spacing:         "14dp"
                adaptive_height: True

                WCard:
                    size_hint_y: None
                    height:      "390dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "14dp"

                        MDTextField:
                            id:               name_field
                            hint_text:        "Your Full Name"
                            icon_right:       "account-outline"
                            mode:             "rectangle"
                            line_color_focus: 0.424, 0.388, 1, 1

                        MDTextField:
                            id:               email_field
                            hint_text:        "Email Address"
                            icon_right:       "email-outline"
                            mode:             "rectangle"
                            line_color_focus: 0.424, 0.388, 1, 1

                        MDTextField:
                            id:               password_field
                            hint_text:        "Create Password"
                            icon_right:       "lock-outline"
                            password:         True
                            mode:             "rectangle"
                            line_color_focus: 0.424, 0.388, 1, 1

                        MDTextField:
                            id:               confirm_field
                            hint_text:        "Confirm Password"
                            icon_right:       "lock-check-outline"
                            password:         True
                            mode:             "rectangle"
                            line_color_focus: 0.424, 0.388, 1, 1

                        MDLabel:
                            id:               error_label
                            text:             ""
                            theme_text_color: "Custom"
                            text_color:       1, 0.298, 0.298, 1
                            font_size:        "12sp"
                            size_hint_y:      None
                            height:           "18dp"

                        PrimaryButton:
                            text:     "CREATE ACCOUNT"
                            on_press: root.do_signup()

                MDBoxLayout:
                    adaptive_height: True
                    spacing:         "4dp"
                    padding:         ["8dp", "0dp"]

                    SGrey:
                        text:        "Already have an account?"
                        size_hint_x: 0.6
                        height:      "28dp"

                    MDFlatButton:
                        text:       "Login"
                        text_color: 0.424, 0.388, 1, 1
                        on_press:   root.go_to_login()


# ==============================================================
#  SCREEN 3 -- PARENT DASHBOARD
# ==============================================================
<ParentDashboardScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        # Header
        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "175dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["20dp", "42dp", "20dp", "16dp"]
            spacing:      "8dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 32, 32]

            MDBoxLayout:
                adaptive_height: True

                MDBoxLayout:
                    orientation:     "vertical"
                    adaptive_height: True

                    MDLabel:
                        id:               greeting_label
                        text:             "Good Morning, Parent"
                        font_style:       "H5"
                        bold:             True
                        theme_text_color: "Custom"
                        text_color:       1, 1, 1, 1
                        size_hint_y:      None
                        height:           "36dp"

                    MDBoxLayout:
                        adaptive_height: True
                        spacing:         "6dp"

                        MDIcon:
                            icon:             "shield-check"
                            theme_text_color: "Custom"
                            text_color:       0.298, 0.686, 0.314, 1
                            font_size:        "14sp"

                        MDLabel:
                            text:             "All children are safe"
                            theme_text_color: "Custom"
                            text_color:       0.600, 0.900, 0.600, 1
                            font_size:        "13sp"
                            size_hint_y:      None
                            height:           "22dp"

                MDIconButton:
                    icon:             "bell-outline"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_x:      None
                    width:            "40dp"
                    on_press:         root.go_to("notifications")

            # Stat pills row
            MDBoxLayout:
                adaptive_height: True
                spacing:         "12dp"

                MDCard:
                    size_hint_y:  None
                    height:       "36dp"
                    size_hint_x:  None
                    width:        "120dp"
                    md_bg_color:  0.200, 0.340, 0.500, 1
                    radius:       [18, 18, 18, 18]
                    padding:      ["12dp", "4dp"]

                    MDBoxLayout:
                        spacing: "6dp"
                        MDIcon:
                            icon:             "account-group"
                            theme_text_color: "Custom"
                            text_color:       1, 1, 1, 1
                            font_size:        "14sp"
                        MDLabel:
                            text:             "2 Children"
                            theme_text_color: "Custom"
                            text_color:       1, 1, 1, 1
                            font_size:        "12sp"

                MDCard:
                    size_hint_y:  None
                    height:       "36dp"
                    size_hint_x:  None
                    width:        "120dp"
                    md_bg_color:  0.200, 0.340, 0.500, 1
                    radius:       [18, 18, 18, 18]
                    padding:      ["12dp", "4dp"]

                    MDBoxLayout:
                        spacing: "6dp"
                        MDIcon:
                            icon:             "shield-lock-outline"
                            theme_text_color: "Custom"
                            text_color:       1, 0.600, 0.600, 1
                            font_size:        "14sp"
                        MDLabel:
                            text:             "4 Blocked"
                            theme_text_color: "Custom"
                            text_color:       1, 0.700, 0.700, 1
                            font_size:        "12sp"

        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["16dp", "16dp"]
                spacing:         "16dp"
                adaptive_height: True

                STitle:
                    text: "Children Activity"

                # Child 1 card
                WCard:
                    size_hint_y: None
                    height:      "160dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "12dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "12dp"

                            MDCard:
                                size_hint:   None, None
                                size:        "46dp", "46dp"
                                radius:      [23, 23, 23, 23]
                                md_bg_color: 0.424, 0.388, 1, 0.15

                                MDIcon:
                                    icon:             "face-woman"
                                    theme_text_color: "Custom"
                                    text_color:       0.424, 0.388, 1, 1
                                    font_size:        "28sp"
                                    halign:           "center"

                            MDBoxLayout:
                                orientation:     "vertical"
                                adaptive_height: True
                                spacing:         "4dp"

                                MDLabel:
                                    text:             "Sara Ahmed"
                                    font_size:        "16sp"
                                    bold:             True
                                    theme_text_color: "Custom"
                                    text_color:       0.122, 0.227, 0.373, 1
                                    size_hint_y:      None
                                    height:           "24dp"

                                SGrey:
                                    text: "Age 12  --  Samsung A12"

                            MDCard:
                                size_hint_y:  None
                                height:       "26dp"
                                size_hint_x:  None
                                width:        "60dp"
                                md_bg_color:  0.298, 0.686, 0.314, 0.15
                                radius:       [13, 13, 13, 13]
                                padding:      ["6dp", "2dp"]

                                MDLabel:
                                    text:             "Online"
                                    theme_text_color: "Custom"
                                    text_color:       0.298, 0.686, 0.314, 1
                                    font_size:        "11sp"
                                    bold:             True
                                    halign:           "center"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "8dp"

                            MDIcon:
                                icon:             "clock-outline"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                font_size:        "16sp"
                                size_hint_x:      None
                                width:            "20dp"

                            MDBoxLayout:
                                orientation: "vertical"
                                spacing:     "4dp"

                                MDBoxLayout:
                                    adaptive_height: True

                                    SGrey:
                                        text:   "Screen Time"
                                        height: "18dp"

                                    MDLabel:
                                        text:             "2h 15m / 4h"
                                        halign:           "right"
                                        font_size:        "12sp"
                                        bold:             True
                                        theme_text_color: "Custom"
                                        text_color:       0.424, 0.388, 1, 1
                                        size_hint_y:      None
                                        height:           "18dp"

                                MDProgressBar:
                                    value:       56
                                    color:       0.424, 0.388, 1, 1
                                    size_hint_y: None
                                    height:      "8dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "8dp"

                            MDFlatButton:
                                text:        "View Details"
                                text_color:  0.424, 0.388, 1, 1
                                size_hint_x: 0.5
                                on_press:    root.go_to("child_dashboard")

                            MDFlatButton:
                                text:        "Block Apps"
                                text_color:  1, 0.298, 0.298, 1
                                size_hint_x: 0.5
                                on_press:    root.go_to("app_block")

                # Child 2 card
                WCard:
                    size_hint_y: None
                    height:      "160dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "12dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "12dp"

                            MDCard:
                                size_hint:   None, None
                                size:        "46dp", "46dp"
                                radius:      [23, 23, 23, 23]
                                md_bg_color: 0.122, 0.227, 0.373, 0.12

                                MDIcon:
                                    icon:             "face-man"
                                    theme_text_color: "Custom"
                                    text_color:       0.122, 0.227, 0.373, 1
                                    font_size:        "28sp"
                                    halign:           "center"

                            MDBoxLayout:
                                orientation:     "vertical"
                                adaptive_height: True
                                spacing:         "4dp"

                                MDLabel:
                                    text:             "Ahmed Ali"
                                    font_size:        "16sp"
                                    bold:             True
                                    theme_text_color: "Custom"
                                    text_color:       0.122, 0.227, 0.373, 1
                                    size_hint_y:      None
                                    height:           "24dp"

                                SGrey:
                                    text: "Age 9  --  Huawei Y9"

                            MDCard:
                                size_hint_y:  None
                                height:       "26dp"
                                size_hint_x:  None
                                width:        "60dp"
                                md_bg_color:  0.478, 0.561, 0.651, 0.15
                                radius:       [13, 13, 13, 13]
                                padding:      ["6dp", "2dp"]

                                MDLabel:
                                    text:             "Offline"
                                    theme_text_color: "Custom"
                                    text_color:       0.478, 0.561, 0.651, 1
                                    font_size:        "11sp"
                                    bold:             True
                                    halign:           "center"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "8dp"

                            MDIcon:
                                icon:             "clock-outline"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                font_size:        "16sp"
                                size_hint_x:      None
                                width:            "20dp"

                            MDBoxLayout:
                                orientation: "vertical"
                                spacing:     "4dp"

                                MDBoxLayout:
                                    adaptive_height: True

                                    SGrey:
                                        text:   "Screen Time"
                                        height: "18dp"

                                    MDLabel:
                                        text:             "1h 30m / 4h"
                                        halign:           "right"
                                        font_size:        "12sp"
                                        bold:             True
                                        theme_text_color: "Custom"
                                        text_color:       0.298, 0.686, 0.314, 1
                                        size_hint_y:      None
                                        height:           "18dp"

                                MDProgressBar:
                                    value:       37
                                    color:       0.298, 0.686, 0.314, 1
                                    size_hint_y: None
                                    height:      "8dp"

                        MDBoxLayout:
                            adaptive_height: True
                            spacing:         "8dp"

                            MDFlatButton:
                                text:        "View Details"
                                text_color:  0.424, 0.388, 1, 1
                                size_hint_x: 0.5
                                on_press:    root.go_to("child_dashboard")

                            MDFlatButton:
                                text:        "Block Apps"
                                text_color:  1, 0.298, 0.298, 1
                                size_hint_x: 0.5
                                on_press:    root.go_to("app_block")

                STitle:
                    text: "Today's Overview"

                # Stats row
                MDBoxLayout:
                    adaptive_height: True
                    spacing:         "12dp"

                    WCard:
                        size_hint_y: None
                        height:      "90dp"
                        size_hint_x: 0.5
                        padding:     "14dp"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "6dp"

                            MDBoxLayout:
                                adaptive_height: True
                                spacing:         "8dp"

                                MDIcon:
                                    icon:             "shield-lock-outline"
                                    theme_text_color: "Custom"
                                    text_color:       1, 0.298, 0.298, 1
                                    font_size:        "20sp"

                                MDLabel:
                                    text:             "4"
                                    font_size:        "22sp"
                                    bold:             True
                                    theme_text_color: "Custom"
                                    text_color:       0.122, 0.227, 0.373, 1
                                    size_hint_y:      None
                                    height:           "28dp"

                            SGrey:
                                text: "Apps Blocked"

                    WCard:
                        size_hint_y: None
                        height:      "90dp"
                        size_hint_x: 0.5
                        padding:     "14dp"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "6dp"

                            MDBoxLayout:
                                adaptive_height: True
                                spacing:         "8dp"

                                MDIcon:
                                    icon:             "bell-alert-outline"
                                    theme_text_color: "Custom"
                                    text_color:       0.980, 0.600, 0.100, 1
                                    font_size:        "20sp"

                                MDLabel:
                                    text:             "3"
                                    font_size:        "22sp"
                                    bold:             True
                                    theme_text_color: "Custom"
                                    text_color:       0.122, 0.227, 0.373, 1
                                    size_hint_y:      None
                                    height:           "28dp"

                            SGrey:
                                text: "New Alerts"

                # ── QUICK CONTROLS ───────────────────────────
                STitle:
                    text: "Quick Controls"

                MDGridLayout:
                    cols:            2
                    spacing:         "12dp"
                    adaptive_height: True

                    # App Blocking tile
                    WCard:
                        size_hint_y: None
                        height:      "100dp"
                        on_touch_down:
                            if self.collide_point(*args[1].pos): root.go_to("app_block")

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "6dp"

                            MDIcon:
                                icon:             "shield-lock-outline"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                font_size:        "32sp"
                                halign:           "center"

                            MDLabel:
                                text:             "App Blocking"
                                halign:           "center"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                font_size:        "13sp"
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "4 apps blocked"
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                font_size:        "11sp"
                                size_hint_y:      None
                                height:           "18dp"

                    # Screen Time tile
                    WCard:
                        size_hint_y: None
                        height:      "100dp"
                        on_touch_down:
                            if self.collide_point(*args[1].pos): root.go_to("screen_time")

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "6dp"

                            MDIcon:
                                icon:             "clock-time-four-outline"
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                font_size:        "32sp"
                                halign:           "center"

                            MDLabel:
                                text:             "Screen Time"
                                halign:           "center"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                font_size:        "13sp"
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "Limit: 4 hrs/day"
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       0.478, 0.561, 0.651, 1
                                font_size:        "11sp"
                                size_hint_y:      None
                                height:           "18dp"

                    # Location tile
                    WCard:
                        size_hint_y: None
                        height:      "100dp"
                        on_touch_down:
                            if self.collide_point(*args[1].pos): root.go_to("location")

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "6dp"

                            MDIcon:
                                icon:             "map-marker-radius-outline"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                font_size:        "32sp"
                                halign:           "center"

                            MDLabel:
                                text:             "Location"
                                halign:           "center"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                font_size:        "13sp"
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "Bahawalpur, Punjab"
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                font_size:        "11sp"
                                size_hint_y:      None
                                height:           "18dp"

                    # Alerts tile
                    WCard:
                        size_hint_y: None
                        height:      "100dp"
                        on_touch_down:
                            if self.collide_point(*args[1].pos): root.go_to("notifications")

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "6dp"

                            MDIcon:
                                icon:             "bell-alert-outline"
                                theme_text_color: "Custom"
                                text_color:       0.980, 0.600, 0.100, 1
                                font_size:        "32sp"
                                halign:           "center"

                            MDLabel:
                                text:             "Alerts"
                                halign:           "center"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                font_size:        "13sp"
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "3 new alerts"
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       0.980, 0.600, 0.100, 1
                                font_size:        "11sp"
                                size_hint_y:      None
                                height:           "18dp"

                    # ── SMART SCHEDULE TILE (FIX 2) ──────────
                    WCard:
                        size_hint_y: None
                        height:      "100dp"
                        on_touch_down:
                            if self.collide_point(*args[1].pos): root.go_to("smart_schedule")

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "6dp"

                            MDIcon:
                                icon:             "calendar-clock"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                font_size:        "32sp"
                                halign:           "center"

                            MDLabel:
                                text:             "Schedule"
                                halign:           "center"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                font_size:        "13sp"
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "Time-based control"
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                font_size:        "11sp"
                                size_hint_y:      None
                                height:           "18dp"

                    # Screen Time Control tile
                    WCard:
                        size_hint_y: None
                        height:      "100dp"
                        on_touch_down:
                            if self.collide_point(*args[1].pos): root.go_to("screen_time")

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "6dp"

                            MDIcon:
                                icon:             "chart-bar"
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                font_size:        "32sp"
                                halign:           "center"

                            MDLabel:
                                text:             "Reports"
                                halign:           "center"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                font_size:        "13sp"
                                size_hint_y:      None
                                height:           "20dp"

                            MDLabel:
                                text:             "Weekly summary"
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       0.478, 0.561, 0.651, 1
                                font_size:        "11sp"
                                size_hint_y:      None
                                height:           "18dp"

                Widget:
                    size_hint_y: None
                    height:      "8dp"

        # Bottom Nav
        MDBoxLayout:
            size_hint_y:  None
            height:       "68dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["4dp", "4dp"]

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "home-variant"
                    theme_text_color: "Custom"
                    text_color:       0.424, 0.388, 1, 1
                MDLabel:
                    text:             "Home"
                    halign:           "center"
                    font_size:        "10sp"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.424, 0.388, 1, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "clock-time-four-outline"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_to("screen_time")
                MDLabel:
                    text:             "Screen"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "map-marker-radius-outline"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_to("location")
                MDLabel:
                    text:             "Location"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "cog-outline"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_to("settings")
                MDLabel:
                    text:             "Settings"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"


# ==============================================================
#  SCREEN 4 -- CHILD DASHBOARD
# ==============================================================
<ChildDashboardScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "210dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["20dp", "42dp", "20dp", "16dp"]
            spacing:      "10dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 32, 32]

            MDBoxLayout:
                adaptive_height: True
                spacing:         "8dp"

                MDIconButton:
                    icon:             "arrow-left"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    on_press:         root.go_back()

                MDLabel:
                    text:             "Child Profile"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_y:      None
                    height:           "36dp"

            MDBoxLayout:
                adaptive_height: True
                spacing:         "16dp"

                MDCard:
                    size_hint:   None, None
                    size:        "64dp", "64dp"
                    radius:      [32, 32, 32, 32]
                    md_bg_color: 0.424, 0.388, 1, 0.25
                    elevation:   4

                    MDIcon:
                        icon:             "face-woman"
                        theme_text_color: "Custom"
                        text_color:       1, 1, 1, 1
                        font_size:        "38sp"
                        halign:           "center"

                MDBoxLayout:
                    orientation:     "vertical"
                    adaptive_height: True
                    spacing:         "6dp"

                    MDLabel:
                        text:             "Sara Ahmed"
                        font_size:        "20sp"
                        bold:             True
                        theme_text_color: "Custom"
                        text_color:       1, 1, 1, 1
                        size_hint_y:      None
                        height:           "30dp"

                    MDBoxLayout:
                        adaptive_height: True
                        spacing:         "8dp"

                        MDCard:
                            size_hint_y:  None
                            height:       "24dp"
                            size_hint_x:  None
                            width:        "58dp"
                            md_bg_color:  0.298, 0.686, 0.314, 0.30
                            radius:       [12, 12, 12, 12]
                            padding:      ["6dp", "2dp"]

                            MDLabel:
                                text:             "Online"
                                theme_text_color: "Custom"
                                text_color:       0.200, 0.800, 0.200, 1
                                font_size:        "11sp"
                                bold:             True
                                halign:           "center"

                        MDLabel:
                            text:             "Age 12  --  Samsung A12"
                            theme_text_color: "Custom"
                            text_color:       0.600, 0.733, 0.900, 1
                            font_size:        "12sp"
                            size_hint_y:      None
                            height:           "22dp"

        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["16dp", "16dp"]
                spacing:         "14dp"
                adaptive_height: True

                STitle:
                    text: "Today at a Glance"

                MDBoxLayout:
                    adaptive_height: True
                    spacing:         "10dp"

                    WCard:
                        size_hint_y: None
                        height:      "90dp"
                        size_hint_x: 0.33
                        padding:     "10dp"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "4dp"

                            MDIcon:
                                icon:             "clock-outline"
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                font_size:        "24sp"
                                halign:           "center"

                            MDLabel:
                                text:             "2h 15m"
                                font_size:        "12sp"
                                bold:             True
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "22dp"

                            SGrey:
                                text:   "Screen"
                                halign: "center"

                    WCard:
                        size_hint_y: None
                        height:      "90dp"
                        size_hint_x: 0.33
                        padding:     "10dp"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "4dp"

                            MDIcon:
                                icon:             "shield-lock-outline"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                font_size:        "24sp"
                                halign:           "center"

                            MDLabel:
                                text:             "4"
                                font_size:        "12sp"
                                bold:             True
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                size_hint_y:      None
                                height:           "22dp"

                            SGrey:
                                text:   "Blocked"
                                halign: "center"

                    WCard:
                        size_hint_y: None
                        height:      "90dp"
                        size_hint_x: 0.33
                        padding:     "10dp"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "4dp"

                            MDIcon:
                                icon:             "map-marker-check"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                font_size:        "24sp"
                                halign:           "center"

                            MDLabel:
                                text:             "Safe"
                                font_size:        "12sp"
                                bold:             True
                                halign:           "center"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                size_hint_y:      None
                                height:           "22dp"

                            SGrey:
                                text:   "Location"
                                halign: "center"

                STitle:
                    text: "Screen Time"

                WCard:
                    size_hint_y: None
                    height:      "110dp"

                    MDBoxLayout:
                        orientation: "vertical"
                        spacing:     "10dp"

                        MDBoxLayout:
                            adaptive_height: True

                            MDLabel:
                                text:             "Daily Usage"
                                font_size:        "14sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "24dp"

                            MDLabel:
                                text:             "2h 15m of 4h"
                                halign:           "right"
                                font_size:        "14sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.424, 0.388, 1, 1
                                size_hint_y:      None
                                height:           "24dp"

                        MDProgressBar:
                            value:       56
                            color:       0.424, 0.388, 1, 1
                            size_hint_y: None
                            height:      "10dp"

                        SGrey:
                            text: "56% used  --  1h 45m remaining today"

                STitle:
                    text: "Quick Actions"

                MDBoxLayout:
                    adaptive_height: True
                    spacing:         "12dp"

                    PrimaryButton:
                        text:        "Manage Apps"
                        size_hint_x: 0.5
                        on_press:    root.go_to("app_block")

                    MDRaisedButton:
                        text:        "Set Time"
                        size_hint_x: 0.5
                        height:      "54dp"
                        radius:      [27, 27, 27, 27]
                        md_bg_color: 0.961, 0.969, 0.980, 1
                        text_color:  0.122, 0.227, 0.373, 1
                        elevation:   1
                        on_press:    root.go_to("screen_time")

                Widget:
                    size_hint_y: None
                    height:      "8dp"

        MDBoxLayout:
            size_hint_y:  None
            height:       "68dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["4dp", "4dp"]

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "home-variant"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_back()
                MDLabel:
                    text: "Home"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "clock-time-four-outline"
                    theme_text_color: "Custom"
                    text_color: 0.424, 0.388, 1, 1
                    on_press: root.go_to("screen_time")
                MDLabel:
                    text: "Screen"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.424, 0.388, 1, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "map-marker-radius-outline"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_to("location")
                MDLabel:
                    text: "Location"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing: "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon: "cog-outline"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    on_press: root.go_to("settings")
                MDLabel:
                    text: "Settings"
                    halign: "center"
                    font_size: "10sp"
                    theme_text_color: "Custom"
                    text_color: 0.478, 0.561, 0.651, 1
                    size_hint_y: None
                    height: "14dp"



<AppBlockScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "158dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["20dp", "42dp", "20dp", "16dp"]
            spacing:      "8dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 32, 32]

            MDBoxLayout:
                adaptive_height: True
                spacing:         "8dp"

                MDIconButton:
                    icon:             "arrow-left"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    on_press:         root.go_back()

                MDLabel:
                    text:             "App Blocking"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_y:      None
                    height:           "36dp"

            MDCard:
                size_hint_y:  None
                height:       "30dp"
                size_hint_x:  None
                width:        "110dp"
                md_bg_color:  1, 0.298, 0.298, 0.25
                radius:       [15, 15, 15, 15]
                padding:      ["10dp", "4dp"]

                MDBoxLayout:
                    spacing: "6dp"
                    MDIcon:
                        icon:             "shield-lock-outline"
                        theme_text_color: "Custom"
                        text_color:       1, 0.600, 0.600, 1
                        font_size:        "14sp"
                    MDLabel:
                        id:               blocked_count_label
                        text:             "3 Blocked"
                        theme_text_color: "Custom"
                        text_color:       1, 0.700, 0.700, 1
                        font_size:        "12sp"
                        bold:             True

        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["16dp", "16dp"]
                spacing:         "10dp"
                adaptive_height: True
                md_bg_color:     0.961, 0.969, 0.980, 1

                # Social Media heading
                MDBoxLayout:
                    size_hint_y:  None
                    height:       "40dp"
                    md_bg_color:  0.961, 0.969, 0.980, 1
                    MDLabel:
                        text:             "Social Media"
                        font_style:       "H6"
                        bold:             True
                        theme_text_color: "Custom"
                        text_color:       0.122, 0.227, 0.373, 1

                # TikTok
                WCard:
                    size_hint_y: None
                    height:      "74dp"
                    id:          tiktok_card
                    md_bg_color: 1, 0.950, 0.950, 1

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "44dp", "44dp"
                            radius:      [22, 22, 22, 22]
                            md_bg_color: 0.050, 0.050, 0.050, 1
                            MDIcon:
                                icon:             "music-note"
                                theme_text_color: "Custom"
                                text_color:       1, 1, 1, 1
                                font_size:        "22sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "2dp"
                            MDLabel:
                                text:             "TikTok"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "24dp"
                            MDLabel:
                                id:               tiktok_status
                                text:             "BLOCKED  --  High risk"
                                font_size:        "11sp"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDSwitch:
                            active:             True
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 1, 0.298, 0.298, 1
                            on_active:
                                root.toggle_app("TikTok", self.active)
                                tiktok_status.text = "BLOCKED  --  High risk" if self.active else "Allowed  --  High risk"
                                tiktok_status.text_color = (1, 0.298, 0.298, 1) if self.active else (0.298, 0.686, 0.314, 1)
                                tiktok_card.md_bg_color = (1, 0.950, 0.950, 1) if self.active else (0.940, 0.980, 0.940, 1)

                # Instagram
                WCard:
                    size_hint_y: None
                    height:      "74dp"
                    id:          insta_card
                    md_bg_color: 1, 0.950, 0.950, 1

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "44dp", "44dp"
                            radius:      [22, 22, 22, 22]
                            md_bg_color: 0.514, 0.192, 0.706, 1
                            MDIcon:
                                icon:             "instagram"
                                theme_text_color: "Custom"
                                text_color:       1, 1, 1, 1
                                font_size:        "22sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "2dp"
                            MDLabel:
                                text:             "Instagram"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "24dp"
                            MDLabel:
                                id:               insta_status
                                text:             "BLOCKED  --  Medium risk"
                                font_size:        "11sp"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDSwitch:
                            active:             True
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 1, 0.298, 0.298, 1
                            on_active:
                                root.toggle_app("Instagram", self.active)
                                insta_status.text = "BLOCKED  --  Medium risk" if self.active else "Allowed  --  Medium risk"
                                insta_status.text_color = (1, 0.298, 0.298, 1) if self.active else (0.298, 0.686, 0.314, 1)
                                insta_card.md_bg_color = (1, 0.950, 0.950, 1) if self.active else (0.940, 0.980, 0.940, 1)

                # Snapchat
                WCard:
                    size_hint_y: None
                    height:      "74dp"
                    id:          snap_card
                    md_bg_color: 0.940, 0.980, 0.940, 1

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "44dp", "44dp"
                            radius:      [22, 22, 22, 22]
                            md_bg_color: 0.980, 0.820, 0, 1
                            MDIcon:
                                icon:             "snapchat"
                                theme_text_color: "Custom"
                                text_color:       0.1, 0.1, 0.1, 1
                                font_size:        "22sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "2dp"
                            MDLabel:
                                text:             "Snapchat"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "24dp"
                            MDLabel:
                                id:               snap_status
                                text:             "Allowed  --  Medium risk"
                                font_size:        "11sp"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDSwitch:
                            active:             False
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 1, 0.298, 0.298, 1
                            on_active:
                                root.toggle_app("Snapchat", self.active)
                                snap_status.text = "BLOCKED  --  Medium risk" if self.active else "Allowed  --  Medium risk"
                                snap_status.text_color = (1, 0.298, 0.298, 1) if self.active else (0.298, 0.686, 0.314, 1)
                                snap_card.md_bg_color = (1, 0.950, 0.950, 1) if self.active else (0.940, 0.980, 0.940, 1)

                # Games heading
                MDBoxLayout:
                    size_hint_y:  None
                    height:       "40dp"
                    md_bg_color:  0.961, 0.969, 0.980, 1
                    MDLabel:
                        text:             "Games"
                        font_style:       "H6"
                        bold:             True
                        theme_text_color: "Custom"
                        text_color:       0.122, 0.227, 0.373, 1

                # PUBG
                WCard:
                    size_hint_y: None
                    height:      "74dp"
                    id:          pubg_card
                    md_bg_color: 1, 0.950, 0.950, 1

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "44dp", "44dp"
                            radius:      [22, 22, 22, 22]
                            md_bg_color: 0.900, 0.500, 0.100, 1
                            MDIcon:
                                icon:             "controller-classic"
                                theme_text_color: "Custom"
                                text_color:       1, 1, 1, 1
                                font_size:        "22sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "2dp"
                            MDLabel:
                                text:             "PUBG Mobile"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "24dp"
                            MDLabel:
                                id:               pubg_status
                                text:             "BLOCKED  --  High risk"
                                font_size:        "11sp"
                                theme_text_color: "Custom"
                                text_color:       1, 0.298, 0.298, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDSwitch:
                            active:             True
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 1, 0.298, 0.298, 1
                            on_active:
                                root.toggle_app("PUBG", self.active)
                                pubg_status.text = "BLOCKED  --  High risk" if self.active else "Allowed  --  High risk"
                                pubg_status.text_color = (1, 0.298, 0.298, 1) if self.active else (0.298, 0.686, 0.314, 1)
                                pubg_card.md_bg_color = (1, 0.950, 0.950, 1) if self.active else (0.940, 0.980, 0.940, 1)

                # Free Fire
                WCard:
                    size_hint_y: None
                    height:      "74dp"
                    id:          ff_card
                    md_bg_color: 0.940, 0.980, 0.940, 1

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "44dp", "44dp"
                            radius:      [22, 22, 22, 22]
                            md_bg_color: 1, 0.300, 0.100, 1
                            MDIcon:
                                icon:             "fire"
                                theme_text_color: "Custom"
                                text_color:       1, 1, 1, 1
                                font_size:        "22sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "2dp"
                            MDLabel:
                                text:             "Free Fire"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "24dp"
                            MDLabel:
                                id:               ff_status
                                text:             "Allowed  --  High risk"
                                font_size:        "11sp"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDSwitch:
                            active:             False
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 1, 0.298, 0.298, 1
                            on_active:
                                root.toggle_app("Free Fire", self.active)
                                ff_status.text = "BLOCKED  --  High risk" if self.active else "Allowed  --  High risk"
                                ff_status.text_color = (1, 0.298, 0.298, 1) if self.active else (0.298, 0.686, 0.314, 1)
                                ff_card.md_bg_color = (1, 0.950, 0.950, 1) if self.active else (0.940, 0.980, 0.940, 1)

                # Video heading
                MDBoxLayout:
                    size_hint_y:  None
                    height:       "40dp"
                    md_bg_color:  0.961, 0.969, 0.980, 1
                    MDLabel:
                        text:             "Video"
                        font_style:       "H6"
                        bold:             True
                        theme_text_color: "Custom"
                        text_color:       0.122, 0.227, 0.373, 1

                # YouTube
                WCard:
                    size_hint_y: None
                    height:      "74dp"
                    id:          yt_card
                    md_bg_color: 0.940, 0.980, 0.940, 1

                    MDBoxLayout:
                        orientation: "horizontal"
                        spacing:     "14dp"

                        MDCard:
                            size_hint:   None, None
                            size:        "44dp", "44dp"
                            radius:      [22, 22, 22, 22]
                            md_bg_color: 1, 0, 0, 1
                            MDIcon:
                                icon:             "youtube"
                                theme_text_color: "Custom"
                                text_color:       1, 1, 1, 1
                                font_size:        "22sp"
                                halign:           "center"

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing:     "2dp"
                            MDLabel:
                                text:             "YouTube"
                                font_size:        "15sp"
                                bold:             True
                                theme_text_color: "Custom"
                                text_color:       0.122, 0.227, 0.373, 1
                                size_hint_y:      None
                                height:           "24dp"
                            MDLabel:
                                id:               yt_status
                                text:             "Allowed  --  Medium risk"
                                font_size:        "11sp"
                                theme_text_color: "Custom"
                                text_color:       0.298, 0.686, 0.314, 1
                                size_hint_y:      None
                                height:           "18dp"

                        MDSwitch:
                            active:             False
                            size_hint_x:        None
                            width:              "56dp"
                            thumb_color_active: 1, 0.298, 0.298, 1
                            on_active:
                                root.toggle_app("YouTube", self.active)
                                yt_status.text = "BLOCKED  --  Medium risk" if self.active else "Allowed  --  Medium risk"
                                yt_status.text_color = (1, 0.298, 0.298, 1) if self.active else (0.298, 0.686, 0.314, 1)
                                yt_card.md_bg_color = (1, 0.950, 0.950, 1) if self.active else (0.940, 0.980, 0.940, 1)

                Widget:
                    size_hint_y: None
                    height:      "12dp"

        # Bottom Nav
        MDBoxLayout:
            size_hint_y:  None
            height:       "68dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["4dp", "4dp"]

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "home-variant"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_back()
                MDLabel:
                    text:             "Home"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "shield-lock-outline"
                    theme_text_color: "Custom"
                    text_color:       0.424, 0.388, 1, 1
                MDLabel:
                    text:             "Blocking"
                    halign:           "center"
                    font_size:        "10sp"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       0.424, 0.388, 1, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "map-marker-radius-outline"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_to("location")
                MDLabel:
                    text:             "Location"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "cog-outline"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_to("settings")
                MDLabel:
                    text:             "Settings"
                    halign:           "center"
                    font_size:        "10sp"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    size_hint_y:      None
                    height:           "14dp"



# ==============================================================
# ============================================================
#  location_screen.kv  --  Real Map Location Screen
#  Yeh file parental.kv mein paste karni hai
#  LocationScreen ki jagah pe
# ============================================================

<LocationScreen>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.961, 0.969, 0.980, 1

        # ── Header ──────────────────────────────────────────
        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "165dp"
            md_bg_color:  0.122, 0.227, 0.373, 1
            padding:      ["20dp", "42dp", "20dp", "16dp"]
            spacing:      "8dp"
            canvas.before:
                RoundedRectangle:
                    pos:    self.pos
                    size:   self.size
                    radius: [0, 0, 32, 32]

            # Back button + title
            MDBoxLayout:
                adaptive_height: True
                spacing:         "8dp"

                MDIconButton:
                    icon:             "arrow-left"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    on_press:         root.go_back()

                MDLabel:
                    text:             "Live Location"
                    font_style:       "H6"
                    bold:             True
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    size_hint_y:      None
                    height:           "36dp"

                MDIconButton:
                    icon:             "refresh"
                    theme_text_color: "Custom"
                    text_color:       1, 1, 1, 1
                    on_press:         root.refresh_location()

            # Live status bar
            MDBoxLayout:
                adaptive_height: True
                spacing:         "8dp"

                MDIcon:
                    icon:             "map-marker-check"
                    theme_text_color: "Custom"
                    text_color:       0.600, 0.933, 0.600, 1
                    font_size:        "16sp"
                    size_hint_x:      None
                    width:            "22dp"

                MDLabel:
                    id:               location_status
                    text:             "Fetching location..."
                    theme_text_color: "Custom"
                    text_color:       0.600, 0.900, 0.600, 1
                    font_size:        "12sp"
                    size_hint_y:      None
                    height:           "22dp"

            # Child selector pills
            MDBoxLayout:
                adaptive_height: True
                spacing:         "10dp"

                MDCard:
                    size_hint_y:  None
                    height:       "32dp"
                    size_hint_x:  None
                    width:        "90dp"
                    md_bg_color:  0.424, 0.388, 1, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    3
                    padding:      ["10dp", "4dp"]

                    MDBoxLayout:
                        spacing: "4dp"
                        MDIcon:
                            icon:             "face-woman"
                            theme_text_color: "Custom"
                            text_color:       1, 1, 1, 1
                            font_size:        "14sp"
                        MDLabel:
                            text:             "Sara"
                            theme_text_color: "Custom"
                            text_color:       1, 1, 1, 1
                            font_size:        "13sp"
                            bold:             True

                MDCard:
                    size_hint_y:  None
                    height:       "32dp"
                    size_hint_x:  None
                    width:        "90dp"
                    md_bg_color:  0.300, 0.430, 0.560, 1
                    radius:       [16, 16, 16, 16]
                    elevation:    1
                    padding:      ["10dp", "4dp"]

                    MDBoxLayout:
                        spacing: "4dp"
                        MDIcon:
                            icon:             "face-man"
                            theme_text_color: "Custom"
                            text_color:       0.800, 0.870, 0.930, 1
                            font_size:        "14sp"
                        MDLabel:
                            text:             "Ahmed"
                            theme_text_color: "Custom"
                            text_color:       0.800, 0.870, 0.930, 1
                            font_size:        "13sp"

        # ── REAL MAP SECTION ────────────────────────────────
        # map_container mein Python se MapView add hoga
        MDBoxLayout:
            id:           map_container
            size_hint_y:  None
            height:       "260dp"
            md_bg_color:  0.851, 0.929, 0.851, 1

        # ── Address info card ───────────────────────────────
        MDBoxLayout:
            orientation:  "vertical"
            size_hint_y:  None
            height:       "80dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["20dp", "10dp"]
            spacing:      "4dp"

            MDBoxLayout:
                adaptive_height: True
                spacing:         "10dp"

                MDIcon:
                    icon:             "map-marker"
                    theme_text_color: "Custom"
                    text_color:       0.424, 0.388, 1, 1
                    font_size:        "20sp"
                    size_hint_x:      None
                    width:            "24dp"

                MDBoxLayout:
                    orientation: "vertical"
                    spacing:     "2dp"

                    MDLabel:
                        id:               address_label
                        text:             "Getting address..."
                        font_size:        "14sp"
                        bold:             True
                        theme_text_color: "Custom"
                        text_color:       0.122, 0.227, 0.373, 1
                        size_hint_y:      None
                        height:           "24dp"

                    MDBoxLayout:
                        adaptive_height: True
                        spacing:         "16dp"

                        MDLabel:
                            id:               coords_label
                            text:             "-- N  --  -- E"
                            font_size:        "11sp"
                            theme_text_color: "Custom"
                            text_color:       0.478, 0.561, 0.651, 1
                            size_hint_y:      None
                            height:           "18dp"

                        MDLabel:
                            id:               time_label
                            text:             "Updated: --"
                            font_size:        "11sp"
                            halign:           "right"
                            theme_text_color: "Custom"
                            text_color:       0.298, 0.686, 0.314, 1
                            size_hint_y:      None
                            height:           "18dp"

        # ── Location History ────────────────────────────────
        ScrollView:
            MDBoxLayout:
                orientation:     "vertical"
                padding:         ["16dp", "12dp"]
                spacing:         "8dp"
                adaptive_height: True

                # History heading
                MDBoxLayout:
                    adaptive_height: True
                    spacing:         "8dp"
                    size_hint_y:     None
                    height:          "36dp"

                    MDLabel:
                        text:             "Location History"
                        font_style:       "H6"
                        bold:             True
                        theme_text_color: "Custom"
                        text_color:       0.122, 0.227, 0.373, 1
                        size_hint_y:      None
                        height:           "36dp"

                    MDLabel:
                        text:             "Today"
                        halign:           "right"
                        font_size:        "12sp"
                        theme_text_color: "Custom"
                        text_color:       0.424, 0.388, 1, 1
                        size_hint_y:      None
                        height:           "36dp"

                # History items -- Python se dynamically fill hoga
                MDBoxLayout:
                    id:              history_container
                    orientation:     "vertical"
                    spacing:         "4dp"
                    adaptive_height: True

                    # Default loading text
                    MDLabel:
                        text:             "Loading history..."
                        font_size:        "13sp"
                        theme_text_color: "Custom"
                        text_color:       0.478, 0.561, 0.651, 1
                        size_hint_y:      None
                        height:           "40dp"

                Widget:
                    size_hint_y: None
                    height:      "12dp"

        # ── Bottom Navigation ───────────────────────────────
        MDBoxLayout:
            size_hint_y:  None
            height:       "68dp"
            md_bg_color:  1, 1, 1, 1
            padding:      ["4dp", "4dp"]

            MDBoxLayout:
                orientation: "vertical"
                spacing:     "2dp"
                size_hint_x: 0.25
                MDIconButton:
                    icon:             "home-variant"
                    theme_text_color: "Custom"
                    text_color:       0.478, 0.561, 0.651, 1
                    on_press:         root.go_back()
                MDLabel:
                    text:             "Home"
                    halign:           "center"
